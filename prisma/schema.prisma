// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  timezone    String      @default("UTC")
  eventTypes  EventType[]
  availability Availability[]
  dateOverrides DateOverride[]
  bookings    Booking[]   @relation("HostBookings")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model EventType {
  id             String    @id @default(cuid())
  userId         String
  title          String
  description    String?
  slug           String    @unique
  duration       Int
  bufferBefore   Int       @default(0)
  bufferAfter    Int       @default(0)
  isActive       Boolean   @default(true)
  bookings       Booking[]
  customQuestions Json?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([slug])
}

model Availability {
  id         String   @id @default(cuid())
  userId     String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isEnabled  Boolean  @default(true)
  timezone   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, dayOfWeek])
}

model DateOverride {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  isBlocked Boolean  @default(true)
  note      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model Booking {
  id               String    @id @default(cuid())
  eventTypeId      String
  userId           String
  guestName        String
  guestEmail       String
  guestTimezone    String
  startTime        DateTime
  endTime          DateTime
  status           BookingStatus @default(SCHEDULED)
  cancellationReason String?
  answers          Json?
  eventType        EventType  @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  user             User       @relation("HostBookings", fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([eventTypeId, startTime])
  @@index([userId, startTime])
  @@index([guestEmail])
  @@unique([eventTypeId, startTime])
}

enum BookingStatus {
  SCHEDULED
  CANCELLED
}
